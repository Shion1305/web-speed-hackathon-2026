{
  "name": "@web-speed-hackathon-2026/application",
  "private": true,
  "license": "MPL-2.0",
  "author": "CyberAgent, Inc.",
  "type": "module",
  "scripts": {
    "build": "bun --filter @web-speed-hackathon-2026/client build",
    "start": "bun --filter @web-speed-hackathon-2026/server start",
    "typecheck": "bun --filter '*' typecheck",
    "format": "pnpm run format:oxlint && pnpm run format:oxfmt",
    "format:oxlint": "oxlint --fix",
    "format:oxfmt": "oxfmt"
  },
  "devDependencies": {
    "oxfmt": "0.36.0",
    "oxlint": "1.43.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "client/",
    "server/",
    "e2e/"
  ],
  "overrides": {
    "gifler>bluebird": "3.7.2",
    "gifler>omggif": "1.0.10"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "bcrypt",
    "esbuild",
    "core-js",
    "sharp",
    "negaposi-analyzer-ja"
  ]
}
